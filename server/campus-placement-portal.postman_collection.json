{
  "info": {
    "name": "Campus Placement Portal API",
    "description": "Run 'npm run seed' first to populate test accounts. Default seed password for every account: Password@123",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:5000/api" },
    { "key": "studentToken", "value": "" },
    { "key": "recruiterToken", "value": "" },
    { "key": "adminToken", "value": "" },
    { "key": "jobId", "value": "" },
    { "key": "companyId", "value": "" },
    { "key": "applicationId", "value": "" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register Student",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/auth/register",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Test Student\",\n  \"email\": \"teststudent@example.com\",\n  \"password\": \"Password@123\",\n  \"college\": \"Test College\",\n  \"branch\": \"CSE\",\n  \"year\": \"Final Year\"\n}"
            }
          }
        },
        {
          "name": "Login - Student",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/auth/login",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"anjali@student.com\",\n  \"password\": \"Password@123\",\n  \"role\": \"student\"\n}"
            }
          }
        },
        {
          "name": "Login - Recruiter",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/auth/login",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"recruiter1@campushire.com\",\n  \"password\": \"Password@123\",\n  \"role\": \"recruiter\"\n}"
            }
          }
        },
        {
          "name": "Login - Admin",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/auth/login",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@campushire.com\",\n  \"password\": \"Password@123\",\n  \"role\": \"admin\"\n}"
            }
          }
        },
        {
          "name": "Get Me",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{studentToken}}" }],
            "url": "{{baseUrl}}/auth/me"
          }
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{studentToken}}" }],
            "url": "{{baseUrl}}/auth/logout"
          }
        }
      ]
    },
    {
      "name": "Student",
      "item": [
        {
          "name": "Get Profile",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{studentToken}}" }],
            "url": "{{baseUrl}}/students/profile"
          }
        },
        {
          "name": "Update Profile",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{studentToken}}" }
            ],
            "url": "{{baseUrl}}/students/profile",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"phone\": \"9999999999\",\n  \"skills\": \"React, Node.js, MongoDB\",\n  \"about\": \"Aspiring full-stack developer.\"\n}"
            }
          }
        },
        {
          "name": "Upload Resume",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{studentToken}}" }],
            "url": "{{baseUrl}}/students/resume",
            "body": {
              "mode": "formdata",
              "formdata": [{ "key": "resume", "type": "file", "src": "" }]
            }
          }
        }
      ]
    },
    {
      "name": "Companies",
      "item": [
        { "name": "List Companies", "request": { "method": "GET", "url": "{{baseUrl}}/companies" } },
        { "name": "Get Company by ID", "request": { "method": "GET", "url": "{{baseUrl}}/companies/{{companyId}}" } },
        {
          "name": "Create Company (Admin)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{adminToken}}" }
            ],
            "url": "{{baseUrl}}/companies",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Microsoft\",\n  \"industry\": \"Technology\",\n  \"website\": \"https://microsoft.com\",\n  \"description\": \"Cloud & productivity software.\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Jobs",
      "item": [
        { "name": "List Jobs (public, ?q=&type=)", "request": { "method": "GET", "url": "{{baseUrl}}/jobs" } },
        { "name": "Get Job by ID", "request": { "method": "GET", "url": "{{baseUrl}}/jobs/{{jobId}}" } },
        {
          "name": "My Posted Jobs (Recruiter)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{recruiterToken}}" }],
            "url": "{{baseUrl}}/jobs/my"
          }
        },
        {
          "name": "Create Job (Recruiter)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{recruiterToken}}" }
            ],
            "url": "{{baseUrl}}/jobs",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"QA Engineer\",\n  \"company\": \"{{companyId}}\",\n  \"description\": \"Own manual and automated testing.\",\n  \"ctc\": \"12 LPA\",\n  \"location\": \"Bengaluru\",\n  \"type\": \"it\",\n  \"skillsRequired\": \"Selenium, Java, Testing\"\n}"
            }
          }
        },
        {
          "name": "Update Job (Recruiter - owner)",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{recruiterToken}}" }
            ],
            "url": "{{baseUrl}}/jobs/{{jobId}}",
            "body": { "mode": "raw", "raw": "{\n  \"ctc\": \"15 LPA\",\n  \"status\": \"open\"\n}" }
          }
        },
        {
          "name": "Delete Job (Recruiter - owner)",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{recruiterToken}}" }],
            "url": "{{baseUrl}}/jobs/{{jobId}}"
          }
        }
      ]
    },
    {
      "name": "Applications",
      "item": [
        {
          "name": "Apply to Job (Student)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{studentToken}}" }
            ],
            "url": "{{baseUrl}}/applications",
            "body": { "mode": "raw", "raw": "{\n  \"jobId\": \"{{jobId}}\"\n}" }
          }
        },
        {
          "name": "My Applications (Student)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{studentToken}}" }],
            "url": "{{baseUrl}}/applications/my"
          }
        },
        {
          "name": "Applicants for a Job (Recruiter)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{recruiterToken}}" }],
            "url": "{{baseUrl}}/applications/job/{{jobId}}"
          }
        },
        {
          "name": "Update Application Status (Recruiter)",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{recruiterToken}}" }
            ],
            "url": "{{baseUrl}}/applications/{{applicationId}}/status",
            "body": { "mode": "raw", "raw": "{\n  \"status\": \"Interview\"\n}" }
          }
        }
      ]
    },
    {
      "name": "Admin",
      "item": [
        {
          "name": "Dashboard Stats",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
            "url": "{{baseUrl}}/admin/stats"
          }
        },
        {
          "name": "List Users (?role=student)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
            "url": "{{baseUrl}}/admin/users"
          }
        },
        {
          "name": "Create Recruiter/Admin User",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{adminToken}}" }
            ],
            "url": "{{baseUrl}}/admin/users",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"New Recruiter\",\n  \"email\": \"newrecruiter@campushire.com\",\n  \"password\": \"Password@123\",\n  \"role\": \"recruiter\",\n  \"company\": \"{{companyId}}\"\n}"
            }
          }
        },
        {
          "name": "Deactivate/Activate User",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{adminToken}}" }
            ],
            "url": "{{baseUrl}}/admin/users/:id/status",
            "body": { "mode": "raw", "raw": "{\n  \"isActive\": false\n}" }
          }
        },
        {
          "name": "Delete User",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
            "url": "{{baseUrl}}/admin/users/:id"
          }
        },
        {
          "name": "All Jobs (Admin)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
            "url": "{{baseUrl}}/admin/jobs"
          }
        },
        {
          "name": "Delete Job (Admin)",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
            "url": "{{baseUrl}}/admin/jobs/{{jobId}}"
          }
        }
      ]
    }
  ]
}
